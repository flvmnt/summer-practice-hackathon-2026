# Local development only. Do not commit real secret values.
#
# Quick start:
#   1. cp .env.example .env.local
#   2. Generate a session secret: `openssl rand -hex 32`
#   3. Fill DATABASE_URL with your local or Railway Postgres URL
#   4. pnpm db:migrate && pnpm dev

# --- REQUIRED ---

# Postgres connection string. Local example:
#   postgres://postgres:postgres@localhost:5432/showup2move
# Railway example:
#   postgres://postgres:<password>@<railway-host>:5432/railway
DATABASE_URL=postgres://postgres:postgres@localhost:5432/showup2move

# >= 64 hex chars; generate with `openssl rand -hex 32`. iron-session signs
# auth cookies with this, so rotating it logs everyone out.
SESSION_SECRET=replace-with-64-plus-random-hex-characters-000000000000000000000000

# Used by server actions for absolute URLs (calendar invites, share links).
# Local: http://localhost:3000  ·  Railway: https://<your-app>.up.railway.app
PUBLIC_BASE_URL=http://localhost:3000

# --- DEMO + JUDGE MODE ---

# Set to `true` to expose /<locale>/demo and Judge Mode endpoints in production.
ALLOW_DEMO_MODE=false
# Bearer secret required by Judge Mode admin actions when ALLOW_DEMO_MODE=true.
DEMO_MODE_SECRET=
# Set to `true` to allow `pnpm db:seed-demo` to run. Belt-and-braces guard.
ALLOW_DEMO_SEED=false
# Required confirmation phrase, enforced by scripts/seed-demo.ts.
DEMO_SEED_CONFIRM=

# --- AI / GROQ (used after onboarding wave) ---
GROQ_API_KEY=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- CLOUDFLARE R2 (uploads) ---
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
PUBLIC_UPLOAD_BASE_URL=

# --- TRANSACTIONAL EMAIL (optional reminders) ---
RESEND_API_KEY=

# --- EXTERNAL DATA (defaults are fine for local dev) ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OVERPASS_BASE_URL=https://overpass-api.de/api
