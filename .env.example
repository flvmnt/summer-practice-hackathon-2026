# Local development only. Do not commit real secret values.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/showup2move
SESSION_SECRET=replace-with-64-plus-random-hex-characters
PUBLIC_BASE_URL=http://localhost:3000

# Demo and Judge Mode
ALLOW_DEMO_MODE=false
DEMO_MODE_SECRET=
ALLOW_DEMO_SEED=false
DEMO_SEED_CONFIRM=

# External services configured in later phases
GROQ_API_KEY=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
PUBLIC_UPLOAD_BASE_URL=
RESEND_API_KEY=
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OVERPASS_BASE_URL=https://overpass-api.de/api
